# Copy this file to .env and fill in your values.
# VITE_ prefix = inlined into the client bundle at build time (never put secrets here).
# Non-VITE_ vars = server-only, never sent to the browser.

# URL of your Railway FastAPI backend (no trailing slash)
VITE_API_URL=https://your-app.up.railway.app

# Optional: add an API key here if your Railway backend requires auth headers
# BACKEND_API_KEY=
